{
  "name": "houseland",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "install:all": "cross-env NODE_ENV=development npm install",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.json --noEmit && vite build && tsc -p tsconfig.server.json",
    "build:render": "npm install --include=dev && npm run build",
    "start": "node scripts/production-start.mjs",
    "preview": "vite preview",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:auth": "tsx scripts/seed-auth-users.ts",
    "db:seed:all": "npm run db:seed:auth && npm run db:seed"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.475.0",
    "prisma": "^6.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.2.0",
    "recharts": "^2.15.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.19.3",
    "typescript": "~5.7.3",
    "vite": "^6.2.0"
  }
}
