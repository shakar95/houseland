# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Server only — for npm run db:seed:auth (never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database — Session pooler (Render + app runtime). Encode @=%40, #=%23
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD_ENCODED@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=30

# API — leave VITE_API_URL empty in dev (Vite proxies /api → PORT)
PORT=3002
VITE_API_URL=

# Agency defaults (seed / fallback)
AGENCY_PHONE=+9647700000000
AGENCY_WHATSAPP=+9647700000000
